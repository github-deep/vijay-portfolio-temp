---
import { siteConfig } from '../../data/siteConfig';
---

<footer class="footer">
  <div class="footer__inner container">
    <div class="footer__left">
      <span class="footer__name">{siteConfig.name}</span>
      <span class="footer__sep">·</span>
      <span class="footer__copy">&copy; {new Date().getFullYear()}</span>
    </div>
    <div class="footer__right">
      {siteConfig.social.instagram && (
        <a href={siteConfig.social.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram">IG</a>
      )}
      {siteConfig.social.youtube && (
        <a href={siteConfig.social.youtube} target="_blank" rel="noopener noreferrer" aria-label="YouTube">YT</a>
      )}
      {siteConfig.social.twitter && (
        <a href={siteConfig.social.twitter} target="_blank" rel="noopener noreferrer" aria-label="Twitter">TW</a>
      )}
      {siteConfig.social.linkedin && (
        <a href={siteConfig.social.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">LI</a>
      )}
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border-light);
    padding: var(--space-xl) 0;
    margin-top: var(--space-3xl);
  }

  .footer__inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  .footer__left {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 0.85rem;
    color: var(--text-tertiary);
  }

  .footer__name {
    font-family: var(--font-display);
    font-size: 0.95rem;
    color: var(--text-secondary);
  }

  .footer__right {
    display: flex;
    gap: var(--space-md);
  }

  .footer__right a {
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    color: var(--text-tertiary);
    transition: color 0.2s;
  }

  .footer__right a:hover {
    color: var(--text-primary);
  }
</style>
