---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Not Found">
  <section class="not-found">
    <div class="container">
      <div class="not-found__inner">
        <span class="not-found__code">404</span>
        <h1 class="not-found__title">This page wandered off</h1>
        <p class="not-found__text">The page you're looking for doesn't exist, or it moved somewhere else.</p>
        <a href="/" class="not-found__link">← Back to home</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding-top: 64px;
  }

  .not-found__inner {
    max-width: 400px;
  }

  .not-found__code {
    font-family: var(--font-display);
    font-size: 6rem;
    color: var(--border-light);
    line-height: 1;
    display: block;
    margin-bottom: var(--space-md);
  }

  .not-found__title {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.8rem;
    color: var(--text-primary);
    margin-bottom: var(--space-md);
  }

  .not-found__text {
    color: var(--text-tertiary);
    margin-bottom: var(--space-xl);
  }

  .not-found__link {
    font-size: 0.9rem;
    color: var(--text-accent);
    font-weight: 500;
    transition: opacity 0.2s;
  }

  .not-found__link:hover {
    opacity: 0.7;
  }
</style>
