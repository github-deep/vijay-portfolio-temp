---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../data/siteConfig';
---

<BaseLayout title="About" description={siteConfig.about.headline}>
  <section class="about-page">
    <div class="container">
      <div class="about-page__layout">
        <!-- Portrait area -->
        <div class="about-page__portrait animate-fade-up">
          <div class="about-page__portrait-frame">
            {siteConfig.about.portrait ? (
              <img
                src={siteConfig.about.portrait}
                alt={siteConfig.name}
                class="about-page__portrait-img"
              />
            ) : (
              <div class="about-page__portrait-placeholder">
                <span>VP</span>
              </div>
            )}
          </div>
        </div>

        <!-- Text content -->
        <div class="about-page__content">
          <h1 class="about-page__headline animate-fade-up">{siteConfig.about.headline}</h1>
          {siteConfig.about.paragraphs.map((para, i) => (
            <p class="about-page__para animate-fade-up" style={`animation-delay: ${0.15 + i * 0.08}s`}>
              {para}
            </p>
          ))}

          <div class="about-page__links animate-fade-up delay-4">
            <a href="/portfolio" class="about-page__link">See my work →</a>
            <a href="/contact" class="about-page__link">Get in touch →</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about-page {
    padding-top: calc(64px + var(--space-lg));
    padding-bottom: var(--space-lg);
    min-height: 100vh;
  }

  .about-page__layout {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: var(--space-2xl);
    align-items: start;
  }

  .about-page__portrait-frame {
    aspect-ratio: 3 / 4;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--border-light);
  }

  .about-page__portrait-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .about-page__portrait-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(160deg, var(--bg-secondary), var(--bg-card));
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 4rem;
    color: var(--text-tertiary);
    letter-spacing: 0.05em;
  }

  .about-page__headline {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    color: var(--text-primary);
    margin-bottom: var(--space-xl);
    line-height: 1.2;
    letter-spacing: -0.01em;
  }

  .about-page__para {
    font-size: clamp(0.95rem, 1.5vw, 1.05rem);
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: var(--space-lg);
    max-width: 560px;
  }

  .about-page__links {
    display: flex;
    gap: var(--space-xl);
    margin-top: var(--space-xl);
  }

  .about-page__link {
    font-size: 0.95rem;
    color: var(--text-accent);
    font-weight: 500;
    transition: opacity 0.2s;
  }

  .about-page__link:hover {
    opacity: 0.7;
  }

  @media (max-width: 768px) {
    .about-page__layout {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }

    .about-page__portrait-frame {
      max-width: 280px;
      aspect-ratio: 1;
      border-radius: 50%;
    }

    .about-page__portrait-placeholder {
      border-radius: 50%;
    }
  }
</style>
