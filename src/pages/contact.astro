---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../data/siteConfig';
---

<BaseLayout title="Contact" description="Get in touch with Vijay Pratap">
  <section class="contact-page">
    <div class="container">
      <div class="contact-page__inner">
        <h1 class="contact-page__title animate-fade-up">Let's talk</h1>
        <p class="contact-page__subtitle animate-fade-up delay-1">
          Whether it's about a collaboration, a project, or just a conversation — I'd love to hear from you.
        </p>

        <div class="contact-page__links animate-fade-up delay-2">
          <a href={`mailto:${siteConfig.social.email}`} class="contact-page__card">
            <div class="contact-page__card-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="2" y="4" width="20" height="16" rx="2"/>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
              </svg>
            </div>
            <div>
              <h3 class="contact-page__card-label">Email</h3>
              <span class="contact-page__card-value">{siteConfig.social.email}</span>
            </div>
          </a>

          {siteConfig.social.instagram && (
            <a href={siteConfig.social.instagram} target="_blank" rel="noopener noreferrer" class="contact-page__card">
              <div class="contact-page__card-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <rect x="2" y="2" width="20" height="20" rx="5"/>
                  <circle cx="12" cy="12" r="5"/>
                  <circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/>
                </svg>
              </div>
              <div>
                <h3 class="contact-page__card-label">Instagram</h3>
                <span class="contact-page__card-value">@vijaypratap</span>
              </div>
            </a>
          )}

          {siteConfig.social.youtube && (
            <a href={siteConfig.social.youtube} target="_blank" rel="noopener noreferrer" class="contact-page__card">
              <div class="contact-page__card-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 1.4-1.4 49.56 49.56 0 0 1 16.2 0A2 2 0 0 1 21.5 7a24.12 24.12 0 0 1 0 10 2 2 0 0 1-1.4 1.4 49.55 49.55 0 0 1-16.2 0A2 2 0 0 1 2.5 17"/>
                  <path d="m10 15 5-3-5-3z"/>
                </svg>
              </div>
              <div>
                <h3 class="contact-page__card-label">YouTube</h3>
                <span class="contact-page__card-value">@vijaypratap</span>
              </div>
            </a>
          )}

          {siteConfig.social.twitter && (
            <a href={siteConfig.social.twitter} target="_blank" rel="noopener noreferrer" class="contact-page__card">
              <div class="contact-page__card-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M4 4l11.733 16h4.267l-11.733 -16zM4 20l6.768 -6.768M15.232 10.232l4.768 -6.232"/>
                </svg>
              </div>
              <div>
                <h3 class="contact-page__card-label">Twitter / X</h3>
                <span class="contact-page__card-value">@vijaypratap</span>
              </div>
            </a>
          )}

          {siteConfig.social.linkedin && (
            <a href={siteConfig.social.linkedin} target="_blank" rel="noopener noreferrer" class="contact-page__card">
              <div class="contact-page__card-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <rect x="2" y="2" width="20" height="20" rx="3"/>
                  <path d="M8 11v5M8 8v.01M12 16v-5M16 16v-3a2 2 0 0 0-4 0"/>
                </svg>
              </div>
              <div>
                <h3 class="contact-page__card-label">LinkedIn</h3>
                <span class="contact-page__card-value">vijaypratap</span>
              </div>
            </a>
          )}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-page {
    padding-top: calc(64px + var(--space-3xl));
    padding-bottom: var(--space-3xl);
    min-height: 100vh;
    display: flex;
    align-items: flex-start;
  }

  .contact-page__inner {
    max-width: 600px;
  }

  .contact-page__title {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(2.5rem, 6vw, 4rem);
    color: var(--text-primary);
    margin-bottom: var(--space-md);
    letter-spacing: -0.02em;
  }

  .contact-page__subtitle {
    font-size: clamp(1rem, 2vw, 1.1rem);
    color: var(--text-secondary);
    margin-bottom: var(--space-2xl);
    max-width: 480px;
    line-height: 1.7;
  }

  .contact-page__links {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .contact-page__card {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    padding: var(--space-lg) var(--space-xl);
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    transition: border-color 0.3s, transform 0.2s var(--ease-out-expo), box-shadow 0.3s;
  }

  .contact-page__card:hover {
    border-color: var(--border-medium);
    transform: translateX(4px);
    box-shadow: var(--shadow-md);
  }

  .contact-page__card-icon {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-secondary);
    border-radius: var(--radius-sm);
    color: var(--text-secondary);
  }

  .contact-page__card-label {
    font-family: var(--font-display);
    font-size: 1.1rem;
    color: var(--text-primary);
    margin-bottom: 2px;
  }

  .contact-page__card-value {
    font-size: 0.85rem;
    color: var(--text-tertiary);
  }
</style>
