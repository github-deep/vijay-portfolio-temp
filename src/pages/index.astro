---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../data/siteConfig';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('portfolio', ({ data }) => !data.draft);
const featuredPosts = allPosts
  .filter(p => p.data.featured)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<BaseLayout>
  <!-- Hero Section -->
  <section class="hero">
    <div class="hero__inner container">
      <div class="hero__content">
        <h1 class="hero__tagline animate-fade-up">
          {siteConfig.tagline.split(' ').map((word, i) => (
            <span class="hero__word" style={`animation-delay: ${i * 0.06}s`}>
              {word}
            </span>
          ))}
        </h1>
        <p class="hero__subtitle animate-fade-up delay-3">
          {siteConfig.description}
        </p>
        <div class="hero__cta animate-fade-up delay-4">
          <a href="/portfolio" class="btn-primary">View my work</a>
          <a href="/about" class="btn-ghost">About me</a>
        </div>
      </div>
      <div class="hero__scroll-hint animate-fade-in delay-5">
        <span>scroll</span>
        <div class="hero__scroll-line"></div>
      </div>
    </div>
  </section>

  <!-- Category Tiles -->
  <section class="categories">
    <div class="container">
      <h2 class="section-title">Explore</h2>
      <div class="categories__grid">
        {siteConfig.categories.map((cat, i) => (
          <a 
            href={`/portfolio?category=${cat.id}`} 
            class="category-tile"
            style={`animation-delay: ${0.1 + i * 0.08}s`}
          >
            <span class="category-tile__icon">{cat.icon}</span>
            <h3 class="category-tile__label">{cat.label}</h3>
            <p class="category-tile__desc">{cat.description}</p>
            <span class="category-tile__arrow">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured Work -->
  {featuredPosts.length > 0 && (
    <section class="featured">
      <div class="container">
        <div class="featured__header">
          <h2 class="section-title">Featured</h2>
          <a href="/portfolio" class="featured__view-all">View all →</a>
        </div>
        <div class="featured__grid">
          {featuredPosts.map((post, i) => (
            <a href={`/portfolio/${post.slug.split('/')[0]}`} class="featured-card" style={`animation-delay: ${0.1 + i * 0.1}s`}>
              <div class="featured-card__image">
                {post.data.thumbnail ? (
                  <img src={post.data.thumbnail.src} alt={post.data.title} loading="lazy" style="width:100%;height:100%;object-fit:cover;" />
                ) : (
                  <div class="featured-card__placeholder">
                    <span>{post.data.category === 'films' ? '🎬' : post.data.category === 'cycling' ? '🚴' : '✍️'}</span>
                  </div>
                )}
              </div>
              <div class="featured-card__body">
                <div class="featured-card__tags">
                  <span class="tag">{post.data.category.replace(/-/g, ' ')}</span>
                  {post.data.tags.slice(0, 2).map((tag: string) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
                <h3 class="featured-card__title">{post.data.title}</h3>
                <p class="featured-card__desc">{post.data.description}</p>
                <time class="featured-card__date">
                  {post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                </time>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  /* ---- Hero ---- */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    position: relative;
    padding-top: 64px;
  }

  .hero__inner {
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: calc(100vh - 64px);
    position: relative;
  }

  .hero__content {
    max-width: 720px;
  }

  .hero__tagline {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--text-primary);
    margin-bottom: var(--space-lg);
    letter-spacing: -0.02em;
  }

  .hero__word {
    display: inline-block;
    margin-right: 0.27em;
    animation: fadeUp 0.6s var(--ease-out-expo) forwards;
    opacity: 0;
  }

  .hero__subtitle {
    font-size: clamp(1rem, 2vw, 1.15rem);
    max-width: 480px;
    margin-bottom: var(--space-xl);
  }

  .hero__cta {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.75rem;
    background: var(--text-primary);
    color: var(--bg-primary);
    font-size: 0.9rem;
    font-weight: 500;
    border-radius: 100px;
    transition: transform 0.2s var(--ease-out-expo), opacity 0.2s;
    letter-spacing: 0.01em;
  }

  .btn-primary:hover {
    transform: translateY(-1px);
    opacity: 0.9;
  }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.75rem;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-secondary);
    border: 1px solid var(--border-medium);
    border-radius: 100px;
    transition: border-color 0.2s, color 0.2s;
    letter-spacing: 0.01em;
  }

  .btn-ghost:hover {
    color: var(--text-primary);
    border-color: var(--text-primary);
  }

  .hero__scroll-hint {
    position: absolute;
    bottom: var(--space-xl);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
    color: var(--text-tertiary);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .hero__scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, var(--text-tertiary), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; transform: scaleY(1); }
    50% { opacity: 1; transform: scaleY(1.2); }
  }

  /* ---- Section Title ---- */
  .section-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2rem);
    color: var(--text-primary);
    margin-bottom: var(--space-xl);
  }

  /* ---- Categories ---- */
  .categories {
    padding: var(--space-3xl) 0;
  }

  .categories__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: var(--space-md);
  }

  .category-tile {
    position: relative;
    padding: var(--space-xl);
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    transition: border-color 0.3s, transform 0.3s var(--ease-out-expo), box-shadow 0.3s;
    animation: fadeUp 0.6s var(--ease-out-expo) forwards;
    opacity: 0;
    overflow: hidden;
  }

  .category-tile:hover {
    border-color: var(--border-medium);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .category-tile__icon {
    font-size: 1.5rem;
    display: block;
    margin-bottom: var(--space-md);
  }

  .category-tile__label {
    font-family: var(--font-display);
    font-size: 1.2rem;
    color: var(--text-primary);
    margin-bottom: var(--space-xs);
  }

  .category-tile__desc {
    font-size: 0.85rem;
    color: var(--text-tertiary);
    line-height: 1.5;
  }

  .category-tile__arrow {
    position: absolute;
    top: var(--space-lg);
    right: var(--space-lg);
    font-size: 1.1rem;
    color: var(--text-tertiary);
    transition: transform 0.3s var(--ease-out-expo), color 0.3s;
  }

  .category-tile:hover .category-tile__arrow {
    transform: translateX(4px);
    color: var(--text-accent);
  }

  /* ---- Featured ---- */
  .featured {
    padding: var(--space-2xl) 0 var(--space-3xl);
  }

  .featured__header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: var(--space-xl);
  }

  .featured__header .section-title {
    margin-bottom: 0;
  }

  .featured__view-all {
    font-size: 0.9rem;
    color: var(--text-tertiary);
    transition: color 0.2s;
  }

  .featured__view-all:hover {
    color: var(--text-accent);
  }

  .featured__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-lg);
  }

  .featured-card {
    display: flex;
    flex-direction: column;
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: border-color 0.3s, transform 0.3s var(--ease-out-expo), box-shadow 0.3s;
    animation: fadeUp 0.6s var(--ease-out-expo) forwards;
    opacity: 0;
  }

  .featured-card:hover {
    border-color: var(--border-medium);
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
  }

  .featured-card__image {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--bg-secondary);
  }

  .featured-card__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    background: linear-gradient(135deg, var(--bg-secondary), var(--bg-card));
  }

  .featured-card__body {
    padding: var(--space-lg);
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .featured-card__tags {
    display: flex;
    gap: var(--space-xs);
    margin-bottom: var(--space-sm);
  }

  .tag {
    display: inline-block;
    padding: 2px 10px;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    text-transform: capitalize;
    background: var(--tag-bg);
    color: var(--tag-text);
    border-radius: 100px;
  }

  .featured-card__title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--text-primary);
    margin-bottom: var(--space-xs);
  }

  .featured-card__desc {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.5;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .featured-card__date {
    font-size: 0.8rem;
    color: var(--text-tertiary);
    margin-top: var(--space-md);
  }

  @media (max-width: 640px) {
    .categories__grid {
      grid-template-columns: 1fr;
    }

    .featured__grid {
      grid-template-columns: 1fr;
    }

    .hero__scroll-hint {
      display: none;
    }
  }
</style>
