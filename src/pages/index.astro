---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../data/siteConfig';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('portfolio', ({ data }) => !data.draft);
const featuredPosts = allPosts
  .filter(p => p.data.featured)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

// SVG icon map for categories (Lucide-style line icons)
const categoryIcons: Record<string, string> = {
  writings: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/></svg>`,
  films: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.2 6 3 11l-.9-2.4c-.3-1.1.3-2.2 1.3-2.5l13.5-4c1.1-.3 2.2.3 2.5 1.3Z"/><path d="m6.2 5.3 3.1 3.9"/><path d="m12.4 3.4 3.1 4"/><path d="M3 11h18v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2Z"/></svg>`,
  cycling: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="18.5" cy="17.5" r="3.5"/><circle cx="5.5" cy="17.5" r="3.5"/><circle cx="15" cy="5" r="1"/><path d="M12 17.5V14l-3-3 4-3 2 3h2"/></svg>`,
  'road-to-wisdom': `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m16.24 7.76-2.12 6.36-6.36 2.12 2.12-6.36z"/></svg>`,
  'data-science': `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M18 17V9"/><path d="M13 17V5"/><path d="M8 17v-3"/></svg>`,
  books: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>`,
  posters: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>`,
};
---

<BaseLayout>
  <!-- Hero Section -->
  <section class="hero">
    <div class="hero__inner container">
      <div class="hero__content">
        <h1 class="hero__tagline animate-fade-up">
          {siteConfig.tagline.split(' ').map((word, i) => (
            <span class="hero__word" style={`animation-delay: ${i * 0.06}s`}>
              {word}
            </span>
          ))}
        </h1>
        <p class="hero__subtitle animate-fade-up delay-3">
          {siteConfig.description}
        </p>
        <div class="hero__cta animate-fade-up delay-4">
          <a href="/portfolio" class="btn-primary">View my work</a>
          <a href="/about" class="btn-ghost">About me</a>
        </div>
      </div>
      <div class="hero__scroll-hint animate-fade-in delay-5">
        <div class="hero__scroll-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 5v14M19 12l-7 7-7-7"/>
          </svg>
        </div>
        <span>scroll</span>
      </div>
    </div>
  </section>

  <!-- Category Tiles -->
  <section class="categories">
    <div class="container">
      <h2 class="section-title">Explore</h2>
      <div class="categories__grid">
        {siteConfig.categories.map((cat, i) => (
          <a 
            href={`/portfolio?category=${cat.id}`} 
            class="category-tile"
            style={`animation-delay: ${0.1 + i * 0.06}s`}
          >
            <div class="category-tile__icon" set:html={categoryIcons[cat.id] || ''} />
            <h3 class="category-tile__label">{cat.label}</h3>
            <p class="category-tile__desc">{cat.description}</p>
            <span class="category-tile__arrow">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured Work -->
  {featuredPosts.length > 0 && (
    <section class="featured">
      <div class="container">
        <div class="featured__header">
          <h2 class="section-title">Featured</h2>
          <a href="/portfolio" class="featured__view-all">View all →</a>
        </div>
        <div class="featured__grid">
          {featuredPosts.map((post, i) => (
            <a href={`/portfolio/${post.slug.split('/')[0]}`} class="featured-card" style={`animation-delay: ${0.1 + i * 0.1}s`}>
              <div class="featured-card__image">
                {post.data.thumbnail ? (
                  <img src={post.data.thumbnail.src} alt={post.data.title} loading="lazy" style="width:100%;height:100%;object-fit:cover;" />
                ) : (
                  <div class="featured-card__placeholder">
                    <div set:html={categoryIcons[post.data.category] || ''} />
                  </div>
                )}
              </div>
              <div class="featured-card__body">
                <div class="featured-card__tags">
                  <span class="tag tag--accent">{post.data.category.replace(/-/g, ' ')}</span>
                  {post.data.tags.slice(0, 2).map((tag: string) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
                <h3 class="featured-card__title">{post.data.title}</h3>
                <p class="featured-card__desc">{post.data.description}</p>
                <time class="featured-card__date">
                  {post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                </time>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  /* ---- Hero ---- */
  .hero {
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: flex-start;
    position: relative;
    padding-top: 64px;
  }

  .hero__inner {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    padding-top: 18vh;
    min-height: calc(100vh - 64px);
    min-height: calc(100dvh - 64px);
    position: relative;
  }

  .hero__content {
    max-width: 720px;
  }

  .hero__tagline {
    font-family: var(--font-display);
    font-weight: 700;
    font-style: italic;
    color: var(--text-primary);
    margin-bottom: var(--space-md);
    letter-spacing: -0.02em;
  }

  .hero__word {
    display: inline-block;
    margin-right: 0.27em;
    animation: fadeUp 0.6s var(--ease-out-expo) forwards;
    opacity: 0;
  }

  .hero__subtitle {
    font-size: clamp(1rem, 2vw, 1.15rem);
    max-width: 480px;
    margin-bottom: var(--space-xl);
  }

  .hero__cta {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    padding: 0.9rem 2.2rem;
    background: var(--text-primary);
    color: var(--bg-primary);
    font-size: 1rem;
    font-weight: 500;
    border-radius: 100px;
    transition: transform 0.2s var(--ease-out-expo), opacity 0.2s;
    letter-spacing: 0.01em;
  }

  .btn-primary:hover {
    transform: translateY(-1px);
    opacity: 0.9;
  }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    padding: 0.9rem 2.2rem;
    font-size: 1rem;
    font-weight: 500;
    color: var(--text-secondary);
    border: 1px solid var(--border-medium);
    border-radius: 100px;
    transition: border-color 0.2s, color 0.2s;
    letter-spacing: 0.01em;
  }

  .btn-ghost:hover {
    color: var(--text-primary);
    border-color: var(--text-primary);
  }

  /* Scroll indicator — visible on all screens */
  .hero__scroll-hint {
    position: absolute;
    bottom: var(--space-xl);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    color: var(--text-tertiary);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    animation: fadeIn 0.5s var(--ease-out-expo) forwards;
    opacity: 0;
    animation-delay: 0.6s;
  }

  .hero__scroll-icon {
    animation: scrollBounce 2s ease-in-out infinite;
  }

  @keyframes scrollBounce {
    0%, 100% { transform: translateY(0); opacity: 0.5; }
    50% { transform: translateY(6px); opacity: 1; }
  }

  /* ---- Section Title ---- */
  .section-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.5rem, 3vw, 2rem);
    color: var(--text-primary);
    margin-bottom: var(--space-lg);
  }

  /* ---- Categories ---- */
  .categories {
    padding: var(--space-xl) 0 var(--space-md);
  }

  .categories__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 10px;
  }

  .category-tile {
    position: relative;
    padding: var(--space-lg);
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    transition: border-color 0.3s, transform 0.3s var(--ease-out-expo), box-shadow 0.3s;
    animation: fadeUp 0.6s var(--ease-out-expo) forwards;
    opacity: 0;
    overflow: hidden;
  }

  .category-tile:hover {
    border-color: var(--border-medium);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .category-tile__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: var(--radius-sm);
    background: var(--bg-secondary);
    color: var(--text-secondary);
    margin-bottom: var(--space-md);
  }

  .category-tile:hover .category-tile__icon {
    color: var(--text-accent);
  }

  .category-tile__label {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.1rem;
    color: var(--text-primary);
    margin-bottom: 2px;
  }

  .category-tile__desc {
    font-size: 0.82rem;
    color: var(--text-tertiary);
    line-height: 1.45;
  }

  .category-tile__arrow {
    position: absolute;
    top: var(--space-lg);
    right: var(--space-lg);
    font-size: 1.1rem;
    color: var(--text-tertiary);
    transition: transform 0.3s var(--ease-out-expo), color 0.3s;
  }

  .category-tile:hover .category-tile__arrow {
    transform: translateX(4px);
    color: var(--text-accent);
  }

  /* ---- Featured ---- */
  .featured {
    padding: var(--space-md) 0 var(--space-lg);
  }

  .featured__header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: var(--space-lg);
  }

  .featured__header .section-title {
    margin-bottom: 0;
  }

  .featured__view-all {
    font-size: 0.9rem;
    color: var(--text-tertiary);
    transition: color 0.2s;
  }

  .featured__view-all:hover {
    color: var(--text-accent);
  }

  .featured__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-md);
  }

  .featured-card {
    display: flex;
    flex-direction: column;
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: border-color 0.3s, transform 0.3s var(--ease-out-expo), box-shadow 0.3s;
    animation: fadeUp 0.6s var(--ease-out-expo) forwards;
    opacity: 0;
  }

  .featured-card:hover {
    border-color: var(--border-medium);
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
  }

  .featured-card__image {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--bg-secondary);
  }

  .featured-card__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-tertiary);
    background: linear-gradient(135deg, var(--bg-secondary), var(--bg-card));
  }

  .featured-card__body {
    padding: var(--space-md) var(--space-lg);
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .featured-card__tags {
    display: flex;
    gap: var(--space-xs);
    margin-bottom: var(--space-sm);
    flex-wrap: wrap;
  }

  .tag {
    display: inline-block;
    padding: 2px 10px;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    text-transform: capitalize;
    background: var(--tag-bg);
    color: var(--tag-text);
    border-radius: 100px;
  }

  .tag--accent {
    background: var(--text-accent);
    color: white;
  }

  .featured-card__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.15rem;
    color: var(--text-primary);
    margin-bottom: 2px;
  }

  .featured-card__desc {
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.5;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .featured-card__date {
    font-size: 0.78rem;
    color: var(--text-tertiary);
    margin-top: var(--space-sm);
  }

  @media (max-width: 640px) {
    .hero__inner {
      padding-top: 15vh;
    }

    .categories__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 8px;
    }

    .category-tile {
      padding: var(--space-md);
    }

    .category-tile__icon {
      width: 40px;
      height: 40px;
      margin-bottom: var(--space-sm);
    }

    .category-tile__icon :global(svg) {
      width: 22px;
      height: 22px;
    }

    .category-tile__label {
      font-size: 0.95rem;
    }

    .category-tile__desc {
      font-size: 0.75rem;
    }

    .category-tile__arrow {
      display: none;
    }

    .featured__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
